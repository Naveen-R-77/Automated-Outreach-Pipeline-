# ==============================================================================
# Automated Outreach Pipeline Environment Configuration Template
# ==============================================================================

# 1. Ocean.io Integration
# ------------------------------------------------------------------------------
OCEAN_IO_API_KEY=YOUR_OCEAN_IO_API_KEY

# 2. Prospeo Integration
# ------------------------------------------------------------------------------
PROSPEO_API_KEY=YOUR_PROSPEO_API_KEY
PROSPEO_API_URL=https://api.prospeo.io/search-person
PROSPEO_REQUEST_DELAY=5
PROSPEO_MAX_RETRIES=4
PROSPEO_CONTACTS_LIMIT=10
# Set to 'true' to filter job titles at the API level (restricts results but saves pages),
# or 'false' to search by domain only and filter case-insensitively locally.
PROSPEO_FILTER_BY_JOB_TITLE=false
OCEAN_IO_MIN_COMPANY_SIZE=11-50

# 3. Brevo Integration (Sendinblue SMTP Transactional API)
# ------------------------------------------------------------------------------
BREVO_API_KEY=YOUR_BREVO_API_KEY
SENDER_EMAIL=naveengowtham999@gmail.com
SENDER_NAME=Naveen

# 4. Pipeline Queue and Rate Limit Configuration
# ------------------------------------------------------------------------------
EMAIL_BATCH_SIZE=50
EMAIL_DELAY_SECONDS=2
BATCH_DELAY_SECONDS=30
